# Local development example.
# Copy this file to .env.local and replace placeholders for services you use.
# Do not commit .env.local, .env, service tokens, database passwords, or production secrets.

# App URLs
NEXT_PUBLIC_API_ENDPOINT=http://localhost:3000
NEXT_PUBLIC_PROD_API_ENDPOINT=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Auth
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-local-secret
# Auth.js also accepts AUTH_SECRET. Keep it aligned with NEXTAUTH_SECRET when set.
AUTH_SECRET=replace-with-local-secret

# PostgreSQL
DATABASE_URL=postgresql://postgres:rootpassword@localhost:5432/library_management
POSTGRES_USER=postgres
POSTGRES_PASSWORD=rootpassword
POSTGRES_DB=library_management
POSTGRES_PORT=5432

# Docker Compose ports
APP_PORT=3000
ADMINER_PORT=8080

# ImageKit
NEXT_PUBLIC_IMAGEKIT_PUBLIC_KEY=
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT=
IMAGEKIT_PRIVATE_KEY=

# Upstash Redis and QStash
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=
QSTASH_URL=
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Email
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@example.com
BREVO_SENDER_NAME=Mundiapolis Library
RESEND_TOKEN=

# Background workflows
ENABLE_WORKFLOWS=false

# Local and CI controls
DISABLE_RATE_LIMIT=true

# Optional API benchmark tuning
BENCH_BASE_URL=http://127.0.0.1:3000
BENCH_WARMUP=5
BENCH_ITERATIONS=20
BENCH_ROUNDS=3
BENCH_BOOKS_LIST_P95_MS=500
BENCH_BOOKS_GENRES_P95_MS=350
BENCH_BOOKS_RECOMMENDATIONS_P95_MS=550
BENCH_BOOK_DETAILS_P95_MS=450

# Optional nightly load-test tuning
LOADTEST_BASE_URL=http://127.0.0.1:3000
LOADTEST_TOTAL_REQUESTS=240
LOADTEST_CONCURRENCY=20
LOADTEST_BOOKS_P95_MS=700
LOADTEST_GENRES_P95_MS=500
LOADTEST_RECOMMENDATIONS_P95_MS=800
LOADTEST_BOOK_ID_P95_MS=650
LOADTEST_MAX_REGRESSION_PERCENT=25
